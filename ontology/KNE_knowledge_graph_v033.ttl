lpt:validDuring a owl:ObjectProperty ;
    rdfs:label "validDuring" ;
    rdfs:comment "Relates an entity such as a fare or service status to an operating period." ;
    rdfs:domain lpt:TransportEntity ;
    rdfs:range lpt:OperatingPeriod .

lpt:LineChange a owl:Class ;
    rdfs:label "LineChange" ;
    rdfs:comment "A change between services as part of a journey. Occurs at exactly one station." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass lpt:Station ;
            owl:onProperty lpt:requiresChangeAt ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

lpt:PermanentClosure a owl:Class ;
    rdfs:label "PermanentClosure" ;
    rdfs:comment "A closure event that is permanent." ;
    rdfs:subClassOf lpt:ClosureEvent .

lpt:StepFreeAccess a owl:Class ;
    rdfs:label "StepFreeAccess" ;
    rdfs:comment "A step-free access feature. Must declare street-to-train availability." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:boolean ;
            owl:onProperty lpt:isStepFreeStreetToTrain ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        lpt:AccessibilityFeature .

lpt:Stop a owl:Class ;
    rdfs:label "Stop" ;
    rdfs:comment "A stop point, especially for bus services." ;
    rdfs:subClassOf lpt:Place .

lpt:affectsSegment a owl:ObjectProperty ;
    rdfs:label "affectsSegment" ;
    rdfs:comment "Indicates which segment is affected by a disruption." ;
    rdfs:domain lpt:DisruptionEvent ;
    rdfs:range lpt:RouteSegment .

lpt:appliesFromZone a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "appliesFromZone" ;
    rdfs:comment "Start fare zone for a fare rule or record." ;
    rdfs:domain lpt:Fare ;
    rdfs:range lpt:FareZone .

lpt:appliesToProduct a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "appliesToProduct" ;
    rdfs:comment "Fare product to which a fare record applies." ;
    rdfs:domain lpt:Fare ;
    rdfs:range lpt:FareProduct .

lpt:appliesToZone a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "appliesToZone" ;
    rdfs:comment "End fare zone for a fare rule or record." ;
    rdfs:domain lpt:Fare ;
    rdfs:range lpt:FareZone .

lpt:closureReason a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "closureReason" ;
    rdfs:comment "The stated reason for closure." ;
    rdfs:domain lpt:ClosureEvent ;
    rdfs:range xsd:string .

lpt:currency a owl:DatatypeProperty,
