lpt:AccessibilityFeature a owl:Class ;
    rdfs:label "AccessibilityFeature" ;
    rdfs:comment "A feature describing accessibility provision." .

lpt:FareProduct a owl:Class ;
    rdfs:label "FareProduct" ;
    rdfs:comment "A fare product such as Oyster adult peak." .

lpt:JourneyOption a owl:Class ;
    rdfs:label "JourneyOption" ;
    rdfs:comment "A possible route option for a journey. Has one start, one end, and uses at least one service." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass lpt:Station ;
            owl:onProperty lpt:startsAt ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass lpt:Station ;
            owl:onProperty lpt:endsAt ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty lpt:usesService ;
            owl:someValuesFrom lpt:ServicePattern ],
        lpt:TransportEntity .

lpt:station_Belsize_Park a lpt:Station,
