@prefix lpt: <http://example.org/lpt-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix schema1: <http://schema.org/> .
@prefix tm: <https://w3id.org/transmodel/commons#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/lpt-ontology> a owl:Ontology ;
    rdfs:label "London Public Transport Ontology" ;
    rdfs:comment "A CQ-driven ontology for a London public transport knowledge graph, enhanced with full OWL 2 TBox axioms (v0.3). Covers stations, lines, branches, termini, interchanges, fare zones, accessibility, service status, closures, fares, buses, and journey planning. Extends Transmodel Ontology (https://w3id.org/transmodel/commons#) and Schema.org (http://schema.org/)." ;
    rdfs:seeAlso schema1:,
        tm: ;
    owl:versionInfo "0.3" .

lpt:AccessibleStation a owl:Class ;
    rdfs:label "AccessibleStation" ;
    rdfs:comment "A station with at least one accessibility feature. Equivalent to: Station and (hasAccessibilityFeature some AccessibilityFeature)." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( lpt:Station [ a owl:Restriction ;
                        owl:onProperty lpt:hasAccessibilityFeature ;
                        owl:someValuesFrom lpt:AccessibilityFeature ] ) ] .

lpt:InterchangeStation a owl:Class ;
    rdfs:label "InterchangeStation" ;
    rdfs:comment "A station served by at least two distinct service patterns. Equivalent to: Station and (servedBy min 2 ServicePattern)." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( lpt:Station [ a owl:Restriction ;
                        owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                        owl:onClass lpt:ServicePattern ;
                        owl:onProperty lpt:servedBy ] ) ] .

lpt:SevereDelay a owl:Class ;
    rdfs:label "SevereDelay" ;
    rdfs:comment "A disruption event representing severe delay." ;
    rdfs:subClassOf lpt:DisruptionEvent .

lpt:connectsToService a owl:ObjectProperty ;
    rdfs:label "connectsToService" ;
    rdfs:comment "Links a station to a rail service directly available from it." ;
    rdfs:domain lpt:Station ;
    rdfs:range lpt:RailService .

lpt:cqCoverageNote a owl:NamedIndividual ;
    rdfs:label "CQ coverage note" ;
    rdfs:comment "This ontology was shaped by competency questions about: Zone 1 Jubilee stations; Victoria direct interchanges; bus routes between Elephant & Castle and Aldwych; step-free access; Central line zones and intersections; Zone 6 non-TfL operators; Temple to Canary Wharf journey planning; Underground/Overground shared stations; Zone 2 DLR stations and Underground links; Northern line branches and termini; plus LLM-augmented questions on District/Circle overlap, Piccadilly accessibility, Victoria line order, King's Cross St Pancras line adjacency, exact-two-line interchanges, and Jubilee intermediate stations." .

lpt:directionName a owl:DatatypeProperty ;
    rdfs:label "directionName" ;
    rdfs:comment "Direction label such as eastbound or northbound." ;
    rdfs:domain lpt:TransportEntity ;
    rdfs:range xsd:string .

lpt:disruption_0001 a lpt:DisruptionEvent,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Central" ;
    lpt:affectsSegment lpt:segment_Central ;
    lpt:closureReason "Central Line: Minor delays due to train cancellations."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-29"^^xsd:date .

lpt:disruption_0003 a lpt:DisruptionEvent,
        owl:NamedIndividual ;
    rdfs:label "Disruption: District" ;
    lpt:affectsSegment lpt:segment_District ;
    lpt:closureReason "District Line: Minor delays between Barking and Upminster due to train cancellations."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-29"^^xsd:date .

lpt:disruption_0004 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: DLR" ;
    lpt:affectsSegment lpt:segment_DLR ;
    lpt:closureReason "DOCKLANDS LIGHT RAILWAY: Saturday 28 and Sunday 29 March, no service between Bank / Tower Gateway and Canning Town / Lewisham, or between Stratford and Canary Wharf. Please use local London Buses and London Underground services. Replacement bus services operate."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-28"^^xsd:date .

lpt:disruption_0005 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Elizabeth line" ;
    lpt:affectsSegment lpt:segment_Elizabeth_line ;
    lpt:closureReason "ELIZABETH LINE: Saturday 28 and Sunday 29 March, no service between Stratford and Shenfield. The limited ELIZABETH LINE services to/from Liverpool Street National Rail station will also not operate. There will also be no GREATER ANGLIA services between Liverpool Street and Ingatestone / Southend Victoria"^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-28"^^xsd:date .

lpt:disruption_0008 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Liberty" ;
    lpt:affectsSegment lpt:segment_Liberty ;
    lpt:closureReason "LIBERTY LINE: Saturday 28 and Sunday 29 March, no service between Romford and Upminster. Use local London Buses routes 165 248 and 370."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-28"^^xsd:date .

lpt:disruption_0010 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Metropolitan" ;
    lpt:affectsSegment lpt:segment_Metropolitan ;
    lpt:closureReason "METROPOLITAN LINE: Saturday 28 and Sunday 29 March, no service between Wembley Park and Aldgate. There will also be no CHILTERN RAILWAYS services between Marylebone and Amersham. Please use JUBILEE LINE connections between Central London and Wembley Park."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-28"^^xsd:date .

lpt:disruption_0011 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Mildmay" ;
    lpt:affectsSegment lpt:segment_Mildmay ;
    lpt:closureReason "MILDMAY LINE: Sunday 29 March, no service between Willesden Junction and Richmond. Use DISTRICT LINE services between Gunnersbury, Kew Gardens and Richmond. Replacement bus service R operates between Willesden Junction and Gunnersbury via Acton Central (The Vale) and South Acton (Acton Lane)"^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-29"^^xsd:date .

lpt:disruption_0016 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Waterloo & City" ;
    lpt:affectsSegment lpt:segment_Waterloo_and_City ;
    lpt:closureReason "Waterloo & City line: service operates 06:00 until 00:30, Monday to Friday only. There is no service on Saturdays, Sundays and on bank/public holidays."^^xsd:string ;
    lpt:endDate "2026-03-29"^^xsd:date ;
    lpt:startDate "2026-03-29"^^xsd:date .

lpt:disruption_0017 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Waterloo & City" ;
    lpt:affectsSegment lpt:segment_Waterloo_and_City ;
    lpt:closureReason "Waterloo and City Line: Service will resume at 06:00 on Monday."^^xsd:string ;
    lpt:endDate "2026-03-29"^^xsd:date ;
    lpt:startDate "2026-03-29"^^xsd:date .

lpt:disruption_0018 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Weaver" ;
    lpt:affectsSegment lpt:segment_Weaver ;
    lpt:closureReason "WEAVER LINE: Saturday 28 and Sunday 29 March, no service between Liverpool Street and Cheshunt / Chingford / Enfield Town. Use VICTORIA LINE connections between Central London and Seven Sisters / Walthamstow Central. GREATER ANGLIA and STANSTED EXPRESS trains will not call at Liverpool Street, Hackney Downs and Seven Sisters, and will be diverted to/from Stratford. Replacement buses operate. If travelling to Tottenham Hotspur Stadium, please use VICTORIA LINE services to/from Seven Sisters or Tottenham Hale."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-28"^^xsd:date .

lpt:disruption_0019 a lpt:TemporaryClosure,
        owl:NamedIndividual ;
    rdfs:label "Disruption: Windrush" ;
    lpt:affectsSegment lpt:segment_Windrush ;
    lpt:closureReason "WINDRUSH LINE: Sunday 29 March, after 1915, no service between Highbury & Islington and Battersea Park / Clapham Junction / Crystal Palace / New Cross / West Croydon. Use MILDMAY LINE services between Highbury & Islington, Canonbury and Dalston Kingsland, and SOUTHERN services between New Cross Gate and Crystal Palace / West Croydon."^^xsd:string ;
    lpt:endDate "2026-03-30"^^xsd:date ;
    lpt:startDate "2026-03-29"^^xsd:date .

lpt:hasBranch a owl:ObjectProperty ;
    rdfs:label "hasBranch" ;
    rdfs:comment "Associates a line with one of its branches." ;
    rdfs:domain lpt:Line ;
    rdfs:range lpt:Branch ;
    owl:inverseOf lpt:branchOfLine .

lpt:hasClosureEvent a owl:ObjectProperty ;
    rdfs:label "hasClosureEvent" ;
    rdfs:comment "Associates a station with a closure event." ;
    rdfs:domain lpt:Station ;
    rdfs:range lpt:ClosureEvent .

lpt:hasConnection a owl:ObjectProperty ;
    rdfs:label "hasConnection" ;
    rdfs:comment "Associates a station with a specific connection object." ;
    rdfs:domain lpt:Station ;
    rdfs:range lpt:Connection .

lpt:hasDirectNationalRailConnection a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "hasDirectNationalRailConnection" ;
    rdfs:comment "A direct connection specifically involving National Rail interchange." ;
    rdfs:subPropertyOf lpt:hasDirectConnectionTo .

lpt:hasIntermediateStation a owl:ObjectProperty ;
    rdfs:label "hasIntermediateStation" ;
    rdfs:comment "Lists intermediate stations on a journey option." ;
    rdfs:domain lpt:JourneyOption ;
    rdfs:range lpt:Station .

lpt:hasStatus a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "hasStatus" ;
    rdfs:comment "Links a service pattern to its current or recent status." ;
    rdfs:domain lpt:ServicePattern ;
    rdfs:range lpt:ServiceStatus .

lpt:hasStepFreeStreetToTrainFeature a owl:ObjectProperty ;
    rdfs:label "hasStepFreeStreetToTrainFeature" ;
    rdfs:comment "A step-free street-to-train accessibility feature." ;
    rdfs:subPropertyOf lpt:hasAccessibilityFeature .

lpt:hasStop a owl:ObjectProperty ;
    rdfs:label "hasStop" ;
    rdfs:comment "Associates a service pattern with its ordered stops or stations." ;
    rdfs:domain lpt:ServicePattern ;
    rdfs:range lpt:Place .

lpt:interchangesWith a owl:ObjectProperty ;
    rdfs:label "interchangesWith" ;
    rdfs:comment "Indicates that interchange with a service is available at a station." ;
    rdfs:domain lpt:Station ;
    rdfs:range lpt:ServicePattern .

lpt:nextStation a owl:ObjectProperty ;
    rdfs:label "nextStation" ;
    rdfs:comment "Links a station to the next station in a given line direction." ;
    rdfs:domain lpt:Station ;
    rdfs:range lpt:Station ;
    owl:inverseOf lpt:previousStation .

lpt:onLine a owl:ObjectProperty ;
    rdfs:label "onLine" ;
    rdfs:comment "Associates an entity with a line." ;
    rdfs:domain lpt:TransportEntity ;
    rdfs:range lpt:Line .

lpt:operatedBy a owl:ObjectProperty ;
    rdfs:label "operatedBy" ;
    rdfs:comment "Links a service pattern to its operator." ;
    rdfs:domain lpt:ServicePattern ;
    rdfs:range lpt:Operator ;
    owl:inverseOf lpt:operates .

lpt:operatingHoursText a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "operatingHoursText" ;
    rdfs:comment "A textual description of operating hours." ;
    rdfs:domain lpt:OperatingPeriod ;
    rdfs:range xsd:string .

lpt:partOfBranch a owl:ObjectProperty ;
    rdfs:label "partOfBranch" ;
    rdfs:comment "Indicates that an entity is part of a specific branch." ;
    rdfs:domain lpt:TransportEntity ;
    rdfs:range lpt:Branch .

lpt:passesThroughHub a owl:ObjectProperty ;
    rdfs:label "passesThroughHub" ;
    rdfs:comment "Indicates that a bus route passes through a given hub." ;
    rdfs:domain lpt:BusRoute ;
    rdfs:range lpt:Hub .

lpt:peakLabel a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "peakLabel" ;
    rdfs:comment "A peak or off-peak label for a fare product." ;
    rdfs:domain lpt:FareProduct ;
    rdfs:range xsd:string .

lpt:servedByBusRoute a owl:ObjectProperty ;
    rdfs:label "servedByBusRoute" ;
    rdfs:comment "Relates a place to a bus route that serves it." ;
    rdfs:range lpt:BusRoute ;
    rdfs:subPropertyOf lpt:servedBy .

lpt:servedByDLR a owl:ObjectProperty ;
    rdfs:label "servedByDLR" ;
    rdfs:comment "Relates a place to the DLR service that serves it." ;
    rdfs:subPropertyOf lpt:servedBy .

lpt:servedByElizabethLine a owl:ObjectProperty ;
    rdfs:label "servedByElizabethLine" ;
    rdfs:comment "Relates a place to the Elizabeth Line service that serves it." ;
    rdfs:subPropertyOf lpt:servedBy .

lpt:servedByOvergroundLine a owl:ObjectProperty ;
    rdfs:label "servedByOvergroundLine" ;
    rdfs:comment "Relates a place to an Overground line that serves it." ;
    rdfs:subPropertyOf lpt:servedBy .

lpt:servedByUndergroundLine a owl:ObjectProperty ;
    rdfs:label "servedByUndergroundLine" ;
    rdfs:comment "Relates a place to an Underground line that serves it." ;
    rdfs:subPropertyOf lpt:servedBy .

lpt:servesArea a owl:ObjectProperty ;
    rdfs:label "servesArea" ;
    rdfs:comment "Relates a bus route to an area or place it serves." ;
    rdfs:domain lpt:BusRoute ;
    rdfs:range lpt:Place .

