lpt:TemporaryClosure a owl:Class ;
    rdfs:label "TemporaryClosure" ;
    rdfs:comment "A temporary closure event. Must have an end date." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:date ;
            owl:onProperty lpt:endDate ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        lpt:ClosureEvent ;
    owl:disjointWith lpt:PermanentClosure .

