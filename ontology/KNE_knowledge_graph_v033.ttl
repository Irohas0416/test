lpt:Branch a owl:Class ;
    rdfs:label "Branch" ;
    rdfs:comment "A branch of a line. Belongs to exactly one line and has at least one terminus." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass lpt:Line ;
            owl:onProperty lpt:branchOfLine ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty lpt:hasTerminus ;
            owl:someValuesFrom lpt:TerminusStation ],
        lpt:TransportEntity .

lpt:Fare a owl:Class ;
    rdfs:label "Fare" ;
    rdfs:comment "A fare record. Has exactly one origin zone, destination zone, product, amount, and currency." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass lpt:FareZone ;
            owl:onProperty lpt:appliesFromZone ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass lpt:FareZone ;
            owl:onProperty lpt:appliesToZone ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass lpt:FareProduct ;
            owl:onProperty lpt:appliesToProduct ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty lpt:fareAmount ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty lpt:currency ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

