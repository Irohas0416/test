        -1.6447e-01 .

xsd:date a rdfs:Datatype .

lpt:BusRoute a owl:Class ;
    rdfs:label "BusRoute" ;
    rdfs:comment "A scheduled bus route. Transport mode is always Bus." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue lpt:Bus ;
            owl:onProperty lpt:hasMode ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty lpt:routeNumber ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        lpt:ServicePattern .

lpt:ClosureEvent a owl:Class ;
    rdfs:label "ClosureEvent" ;
    rdfs:comment "A station closure event. Must have a reason and a start date." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:date ;
            owl:onProperty lpt:startDate ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty lpt:closureReason ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

lpt:DisruptionEvent a owl:Class ;
    rdfs:label "DisruptionEvent" ;
    rdfs:comment "A disruption event affecting operations. Must affect at least one route segment." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty lpt:affectsSegment ;
            owl:someValuesFrom lpt:RouteSegment ] .

lpt:Operator a owl:Class ;
    rdfs:label "Operator" ;
    rdfs:comment "An operator managing transport services. Equivalent to tm:Operator. Identified by operator name." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty lpt:operatorName ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty lpt:operates ;
            owl:someValuesFrom lpt:ServicePattern ] ;
    owl:equivalentClass tm:Operator ;
    owl:hasKey ( lpt:operatorName ) .

