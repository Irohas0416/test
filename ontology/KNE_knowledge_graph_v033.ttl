schema1:Place a owl:Class ;
    rdfs:label "schema:Place" ;
    rdfs:comment "[EXTERNAL — Schema.org] Entities that have a somewhat fixed, physical extension." ;
    rdfs:isDefinedBy schema1: ;
    rdfs:seeAlso schema:Place .

schema1:startDate a owl:DatatypeProperty ;
    rdfs:label "schema:startDate" ;
    rdfs:comment "[EXTERNAL — Schema.org] The start date and time of the item. Equivalent to lpt:startDate." ;
    rdfs:isDefinedBy schema1: ;
    rdfs:seeAlso schema:startDate .

tm:Line a owl:Class ;
    rdfs:label "tm:Line" ;
    rdfs:comment "[EXTERNAL — Transmodel] A group of routes known to the public by a similar name or number." ;
    rdfs:isDefinedBy tm: ;
    rdfs:seeAlso <https://oeg-upm.github.io/snap-docs/> .

tm:Operator a owl:Class ;
    rdfs:label "tm:Operator" ;
    rdfs:comment "[EXTERNAL — Transmodel] A company providing public transport services." ;
    rdfs:isDefinedBy tm: ;
    rdfs:seeAlso <https://oeg-upm.github.io/snap-docs/> .

tm:StopPlace a owl:Class ;
    rdfs:label "tm:StopPlace" ;
    rdfs:comment "[EXTERNAL — Transmodel] A place where vehicles may stop and passengers may board." ;
    rdfs:isDefinedBy tm: ;
    rdfs:seeAlso <https://oeg-upm.github.io/snap-docs/> .

lpt:Connection a owl:Class ;
    rdfs:label "Connection" ;
    rdfs:comment "A direct interchange or connection relationship." .

lpt:FrequencyRecord a owl:Class ;
    rdfs:label "FrequencyRecord" ;
    rdfs:comment "A record describing service frequency." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:decimal ;
            owl:onProperty lpt:frequencyMinutes ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

lpt:Hub a owl:Class ;
    rdfs:label "Hub" ;
    rdfs:comment "A transport hub or interchange area." ;
    rdfs:subClassOf lpt:Place .

lpt:RailService a owl:Class ;
    rdfs:label "RailService" ;
    rdfs:comment "A rail service, including National Rail or similar services." ;
    rdfs:subClassOf lpt:ServicePattern .

lpt:TerminusStation a owl:Class ;
    rdfs:label "TerminusStation" ;
    rdfs:comment "A station that is the terminus of at least one branch. Equivalent to: Station and (inverse(hasTerminus) some Branch)." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( lpt:Station [ a owl:Restriction ;
                        owl:onProperty [ owl:inverseOf lpt:hasTerminus ] ;
                        owl:someValuesFrom lpt:Branch ] ) ] .

lpt:branchOfLine a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "branchOfLine" ;
    rdfs:comment "Relates a branch back to the line it belongs to. Inverse of hasBranch." ;
    rdfs:domain lpt:Branch ;
    rdfs:range lpt:Line .

lpt:endsAt a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "endsAt" ;
    rdfs:comment "The ending station of a route segment or journey option." ;
    rdfs:domain lpt:TransportEntity ;
    rdfs:range lpt:Station .

