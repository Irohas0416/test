lpt:hasTerminus a owl:ObjectProperty ;
    rdfs:label "hasTerminus" ;
    rdfs:comment "Associates a branch with its physical terminus station." ;
    rdfs:domain lpt:Branch ;
    rdfs:range lpt:TerminusStation .

