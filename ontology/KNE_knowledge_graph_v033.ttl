        lpt:station_Gospel_Oak,
        lpt:station_Harringay_Green_Lanes,
        lpt:station_Leyton_Midland_Road,
        lpt:station_Leytonstone_High_Road,
        lpt:station_South_Tottenham,
        lpt:station_Upper_Holloway,
        lpt:station_Walthamstow_Queens_Road,
        lpt:station_Wanstead_Park,
        lpt:station_Woodgrange_Park ;
    lpt:onLine lpt:line_Suffragette ;
    lpt:startsAt lpt:station_Barking_Riverside .

