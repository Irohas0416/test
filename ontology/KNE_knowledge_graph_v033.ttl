    rdfs:domain lpt:Fare ;
    rdfs:range xsd:string .

lpt:endDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "endDate" ;
    rdfs:comment "End date for a period or event." ;
    rdfs:domain lpt:TransportEntity ;
    rdfs:range xsd:date .

lpt:fareAmount a owl:DatatypeProperty,
