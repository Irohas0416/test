        owl:NamedIndividual ;
    rdfs:label "NationalRail" .

lpt:Zone1 a lpt:FareZone,
        owl:NamedIndividual ;
    rdfs:label "Zone1" ;
    lpt:zoneNumber 1 .

lpt:Zone3 a lpt:FareZone,
        owl:NamedIndividual ;
    rdfs:label "Zone3" ;
    lpt:zoneNumber 3 .

lpt:Overground a lpt:TransportMode,
        owl:NamedIndividual ;
    rdfs:label "Overground" .

lpt:Zone2 a lpt:FareZone,
        owl:NamedIndividual ;
    rdfs:label "Zone2" ;
    lpt:zoneNumber 2 .

lpt:Underground a lpt:TransportMode,
        owl:NamedIndividual ;
    rdfs:label "Underground" .

lpt:Station a owl:Class ;
    rdfs:label "Station" ;
    rdfs:comment "A rail or metro station. Has exactly one name and is in at least one fare zone." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onDataRange xsd:string ;
            owl:onProperty lpt:stationName ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty lpt:locatedInZone ;
            owl:someValuesFrom lpt:FareZone ],
        lpt:Place,
        tm:StopPlace ;
    owl:hasKey ( lpt:stationName ) .

[] a owl:AllDisjointClasses ;
    owl:members ( lpt:Station lpt:Stop lpt:Hub ) .

[] a owl:AllDisjointClasses ;
    owl:members ( lpt:Line lpt:BusRoute lpt:RailService ) .

[] a owl:AllDisjointClasses ;
    owl:members ( lpt:Place lpt:ServicePattern lpt:Fare lpt:FareZone lpt:FareProduct lpt:ClosureEvent lpt:DisruptionEvent lpt:Connection lpt:JourneyOption lpt:LineChange lpt:AccessibilityFeature lpt:ServiceStatus lpt:OperatingPeriod lpt:TransportMode lpt:FrequencyRecord lpt:Operator lpt:Branch lpt:RouteSegment ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( lpt:Bus lpt:DLR lpt:ElizabethLineMode lpt:NationalRail lpt:Overground lpt:Underground ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( lpt:Zone1 lpt:Zone2 lpt:Zone3 lpt:Zone4 lpt:Zone5 lpt:Zone6 ) .

